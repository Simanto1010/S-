{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user settings and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User role for access control" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Settings": {
      "title": "User Settings",
      "description": "Stores user preferences and API keys.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "profile": { "type": "object" },
        "apiKeys": { "type": "array" },
        "aiModel": { "type": "object" },
        "voice": { "type": "object" },
        "security": { "type": "object" },
        "devices": { "type": "array" },
        "notifications": { "type": "object" },
        "automation": { "type": "object" }
      },
      "required": ["userId"]
    },
    "HistoryItem": {
      "title": "Command History",
      "description": "Logs of user commands and AI responses.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "command": { "type": "string" },
        "response": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string" }
      },
      "required": ["userId", "command"]
    },
    "VaultItem": {
      "title": "Vault Item",
      "description": "Securely stored credentials.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "service": { "type": "string" },
        "value": { "type": "string" },
        "status": { "type": "string" },
        "lastUsed": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "value"]
    },
    "UserConnector": {
      "title": "User Connector",
      "description": "User's connection status for a platform.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "connectorId": { "type": "string" },
        "status": { "type": "string" },
        "mode": { "type": "string" },
        "connectedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "connectorId", "status"]
    },
    "Workflow": {
      "title": "Automation Workflow",
      "description": "User defined automation sequences.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "nodes": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "nodes"]
    },
    "Goal": {
      "title": "Strategic Goal",
      "description": "User defined strategic goals for AI optimization.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "progress": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title"]
    },
    "AutonomousTask": {
      "title": "Autonomous Task",
      "description": "A task generated by the AI in autonomous mode awaiting approval.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "command": { "type": "string" },
        "explanation": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "executed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "opportunityId": { "type": "string" }
      },
      "required": ["userId", "title", "command", "status"]
    },
    "Opportunity": {
      "title": "AI Detected Opportunity",
      "description": "An opportunity detected by the AI's background analysis.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["inactivity", "trend", "performance", "growth"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "detectedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["new", "processed", "ignored"] }
      },
      "required": ["userId", "type", "title", "status"]
    },
    "Workspace": {
      "title": "Team Workspace",
      "description": "A shared workspace for team collaboration.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "members": { "type": "array", "description": "List of user UIDs and their roles" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId"]
    },
    "Invitation": {
      "title": "Workspace Invitation",
      "description": "An invitation to join a workspace.",
      "type": "object",
      "properties": {
        "workspaceId": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "editor"] },
        "status": { "type": "string", "enum": ["pending", "accepted", "declined"] },
        "invitedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["workspaceId", "email", "role", "status"]
    },
    "TeamActivity": {
      "title": "Team Activity Feed",
      "description": "Logs of team actions like task approvals.",
      "type": "object",
      "properties": {
        "workspaceId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "targetId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["workspaceId", "userId", "action"]
    },
    "AnalyticsData": {
      "title": "Platform Analytics",
      "description": "Historical and predicted performance data.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "platform": { "type": "string" },
        "metric": { "type": "string" },
        "value": { "type": "number" },
        "type": { "type": "string", "enum": ["actual", "predicted"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "platform", "metric", "value", "type"]
    },
    "MemoryEntry": {
      "title": "AI Memory",
      "description": "Long-term semantic memory for AI personalization.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "embedding": { "type": "array" },
        "metadata": { "type": "object" }
      },
      "required": ["userId", "content", "embedding"]
    },
    "SystemError": {
      "title": "System Error Log",
      "description": "Logs of system errors for debugging and AI auto-fixing.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "service": { "type": "string" },
        "error": { "type": "string" },
        "context": { "type": "object" },
        "retryCount": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "resolved": { "type": "boolean" }
      },
      "required": ["userId", "service", "error", "timestamp"]
    },
    "SystemMetric": {
      "title": "System Health Metric",
      "description": "Real-time performance metrics for system monitoring.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "cpu": { "type": "number" },
        "latency": { "type": "number" },
        "successRate": { "type": "number" },
        "activeTasks": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "cpu", "latency", "successRate", "timestamp"]
    },
    "Subscription": {
      "title": "User Subscription",
      "description": "SaaS subscription details and plan information.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "pro"] },
        "status": { "type": "string", "enum": ["active", "canceled", "past_due", "pending_verification"] },
        "paymentMethod": { "type": "string", "enum": ["upi"] },
        "currentPeriodEnd": { "type": "string", "format": "date-time" },
        "features": { "type": "object" },
        "lastTransactionId": { "type": "string" }
      },
      "required": ["userId", "plan", "status"]
    },
    "PaymentRequest": {
      "title": "UPI Payment Request",
      "description": "Manual UPI payment verification request.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "planType": { "type": "string", "enum": ["monthly", "yearly"] },
        "amount": { "type": "number" },
        "transactionId": { "type": "string" },
        "screenshotUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "verifiedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "planType", "amount", "transactionId", "status"]
    },
    "Usage": {
      "title": "Usage Tracking",
      "description": "Tracks user resource consumption for plan limits.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "month": { "type": "string", "description": "YYYY-MM format" },
        "aiCalls": { "type": "number" },
        "executions": { "type": "number" },
        "storageUsed": { "type": "number" }
      },
      "required": ["userId", "month"]
    },
    "AdminLog": {
      "title": "Admin Action Log",
      "description": "Logs of admin activities and security attempts.",
      "type": "object",
      "properties": {
        "adminId": { "type": "string" },
        "email": { "type": "string" },
        "action": { "type": "string" },
        "status": { "type": "string", "enum": ["success", "failed", "denied"] },
        "details": { "type": "string" },
        "ip": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "action", "status", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile data"
    },
    "/settings/{settingsId}": {
      "schema": "Settings",
      "description": "User application settings"
    },
    "/history/{historyId}": {
      "schema": "HistoryItem",
      "description": "User command history"
    },
    "/vault/{vaultId}": {
      "schema": "VaultItem",
      "description": "User secure credentials"
    },
    "/userConnectors/{userConnectorId}": {
      "schema": "UserConnector",
      "description": "User platform connections"
    },
    "/workflows/{workflowId}": {
      "schema": "Workflow",
      "description": "User automation workflows"
    },
    "/goals/{goalId}": {
      "schema": "Goal",
      "description": "User strategic goals"
    },
    "/autonomousTasks/{taskId}": {
      "schema": "AutonomousTask",
      "description": "AI generated tasks queue"
    },
    "/opportunities/{opportunityId}": {
      "schema": "Opportunity",
      "description": "AI detected opportunities"
    },
    "/workspaces/{workspaceId}": {
      "schema": "Workspace",
      "description": "Team workspaces"
    },
    "/invitations/{invitationId}": {
      "schema": "Invitation",
      "description": "Workspace invitations"
    },
    "/teamActivity/{activityId}": {
      "schema": "TeamActivity",
      "description": "Team action logs"
    },
    "/analytics/{analyticsId}": {
      "schema": "AnalyticsData",
      "description": "Performance analytics data"
    },
    "/memories/{memoryId}": {
      "schema": "MemoryEntry",
      "description": "AI long-term memories"
    },
    "/systemErrors/{errorId}": {
      "schema": "SystemError",
      "description": "System error logs"
    },
    "/systemMetrics/{metricId}": {
      "schema": "SystemMetric",
      "description": "System health metrics"
    },
    "/subscriptions/{subscriptionId}": {
      "schema": "Subscription",
      "description": "User SaaS subscriptions"
    },
    "/usage/{usageId}": {
      "schema": "Usage",
      "description": "User usage tracking"
    },
    "/adminLogs/{logId}": {
      "schema": "AdminLog",
      "description": "Admin security and action logs"
    }
  }
}

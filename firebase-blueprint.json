{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user settings and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Settings": {
      "title": "User Settings",
      "description": "Stores user preferences and API keys.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "profile": { "type": "object" },
        "apiKeys": { "type": "array" },
        "aiModel": { "type": "object" },
        "voice": { "type": "object" },
        "security": { "type": "object" },
        "devices": { "type": "array" },
        "notifications": { "type": "object" },
        "automation": { "type": "object" }
      },
      "required": ["userId"]
    },
    "HistoryItem": {
      "title": "Command History",
      "description": "Logs of user commands and AI responses.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "command": { "type": "string" },
        "response": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string" }
      },
      "required": ["userId", "command"]
    },
    "VaultItem": {
      "title": "Vault Item",
      "description": "Securely stored credentials.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "service": { "type": "string" },
        "value": { "type": "string" },
        "status": { "type": "string" },
        "lastUsed": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "value"]
    },
    "UserConnector": {
      "title": "User Connector",
      "description": "User's connection status for a platform.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "connectorId": { "type": "string" },
        "status": { "type": "string" },
        "mode": { "type": "string" },
        "connectedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "connectorId", "status"]
    },
    "Workflow": {
      "title": "Automation Workflow",
      "description": "User defined automation sequences.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "nodes": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "nodes"]
    },
    "Goal": {
      "title": "Strategic Goal",
      "description": "User defined strategic goals for AI optimization.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "progress": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title"]
    },
    "AutonomousTask": {
      "title": "Autonomous Task",
      "description": "A task generated by the AI in autonomous mode awaiting approval.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "command": { "type": "string" },
        "explanation": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "executed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "opportunityId": { "type": "string" }
      },
      "required": ["userId", "title", "command", "status"]
    },
    "Opportunity": {
      "title": "AI Detected Opportunity",
      "description": "An opportunity detected by the AI's background analysis.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["inactivity", "trend", "performance", "growth"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "detectedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["new", "processed", "ignored"] }
      },
      "required": ["userId", "type", "title", "status"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile data"
    },
    "/settings/{settingsId}": {
      "schema": "Settings",
      "description": "User application settings"
    },
    "/history/{historyId}": {
      "schema": "HistoryItem",
      "description": "User command history"
    },
    "/vault/{vaultId}": {
      "schema": "VaultItem",
      "description": "User secure credentials"
    },
    "/userConnectors/{userConnectorId}": {
      "schema": "UserConnector",
      "description": "User platform connections"
    },
    "/workflows/{workflowId}": {
      "schema": "Workflow",
      "description": "User automation workflows"
    },
    "/goals/{goalId}": {
      "schema": "Goal",
      "description": "User strategic goals"
    },
    "/autonomousTasks/{taskId}": {
      "schema": "AutonomousTask",
      "description": "AI generated tasks queue"
    },
    "/opportunities/{opportunityId}": {
      "schema": "Opportunity",
      "description": "AI detected opportunities"
    }
  }
}
